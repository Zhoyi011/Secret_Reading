rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    // A user is owner if their user document role is 'owner'
    // or if their authenticated email is the bootstrap owner 'zhoyilee@gmail.com'
    function isOwner() {
      return isSignedIn() && (
        request.auth.token.email == 'zhoyilee@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUser(request.auth.uid).data.get('role', 'reader') == 'owner')
      );
    }

    // Check if user is author or owner
    function isAuthorOrOwner() {
      return isSignedIn() && (
        request.auth.token.email == 'zhoyilee@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          getUser(request.auth.uid).data.get('role', 'reader') == 'author' ||
          getUser(request.auth.uid).data.get('role', 'reader') == 'owner'
        ))
      );
    }

    match /users/{userId} {
      // Anyone signed in can read a user profile (for display names, roles, etc.)
      allow read: if isSignedIn();

      // Users can create their own profile during registration
      // If the email is bootstrap admin, they can become owner, otherwise they must start as reader
      allow create: if isSignedIn() && request.auth.uid == userId && (
        (request.resource.data.get('email', '') == 'zhoyilee@gmail.com' && request.resource.data.get('role', 'reader') == 'owner') ||
        (request.resource.data.get('email', '') != 'zhoyilee@gmail.com' && request.resource.data.get('role', 'reader') == 'reader')
      );

      // Only the owner can update any user's role
      // Users themselves can update other profile details, but NOT their role
      allow update: if (
        isSignedIn() && request.auth.uid == userId &&
        (request.resource.data.get('role', 'reader') == resource.data.get('role', 'reader'))
      ) || isOwner();

      allow delete: if isOwner();
    }

    match /posts/{postId} {
      // Anyone signed in can read published articles
      // Drafts can only be read by their author or the owner
      allow read: if isSignedIn() && (
        resource.data.status == 'published' ||
        resource.data.authorId == request.auth.uid ||
        isOwner()
      );

      // Only authors or owners can create posts
      allow create: if isAuthorOrOwner() && request.resource.data.authorId == request.auth.uid;

      // Authors can update their own posts. Anyone signed in can update "likes" and "likers"
      // to perform liking operations (with validation checks)
      allow update: if isSignedIn() && (
        // Option A: Author or Owner updates the entire document (content, status, etc.)
        (
          (resource.data.authorId == request.auth.uid || isOwner()) && 
          request.resource.data.authorId == resource.data.authorId
        ) ||
        // Option B: A reader likes/unlikes the document, changing ONLY likes and likers
        (
          request.resource.data.title == resource.data.title &&
          request.resource.data.content == resource.data.content &&
          request.resource.data.authorId == resource.data.authorId &&
          request.resource.data.status == resource.data.status &&
          // Validate that the likes count correlates to the likers list
          request.resource.data.likes == request.resource.data.likers.size()
        )
      );

      // Only the owner can delete any post. Authors can also delete their own draft/posts
      allow delete: if isOwner() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /follows/{followId} {
      // Anyone signed in can read follow relations
      allow read: if isSignedIn();

      // Only the follower themselves can create/remove follow records
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    match /notifications/{notificationId} {
      // Users can read and delete their own notifications
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;

      // Any signed-in user can create a notification (e.g. for follows, likes, or new posts)
      // provided the senderId matches their auth UID
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;

      // Users can mark their own notifications as read
      allow update: if isSignedIn() && 
                    resource.data.recipientId == request.auth.uid && 
                    request.resource.data.read == true && 
                    request.resource.data.recipientId == resource.data.recipientId &&
                    request.resource.data.senderId == resource.data.senderId;
    }

    match /author_applications/{appId} {
      allow read: if isSignedIn() && (request.auth.uid == appId || isOwner());
      allow create: if isSignedIn() && request.auth.uid == appId;
      allow update: if isOwner() || (isSignedIn() && request.auth.uid == appId);
      allow delete: if isOwner();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isOwner();
    }
  }
}
