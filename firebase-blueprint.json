{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profiles with roles and registration info",
      "type": "object",
      "properties": {
        "firebaseUid": {
          "type": "string",
          "description": "The unique Firebase Authentication UID of the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        },
        "username": {
          "type": "string",
          "description": "Display username"
        },
        "birthday": {
          "type": "string",
          "description": "User birthday"
        },
        "avatar": {
          "type": "string",
          "description": "Cloudinary image URL or standard avatar"
        },
        "role": {
          "type": "string",
          "enum": ["reader", "author", "owner"],
          "description": "The authorization role of the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["firebaseUid", "email", "username", "role", "createdAt"]
    },
    "Post": {
      "title": "Article Post",
      "description": "Articles / posts written by authors or owners",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the post"
        },
        "content": {
          "type": "string",
          "description": "Markdown body content"
        },
        "authorId": {
          "type": "string",
          "description": "The Firebase UID of the author"
        },
        "authorName": {
          "type": "string",
          "description": "The display name of the author"
        },
        "images": {
          "type": "array",
          "description": "List of Cloudinary image URLs"
        },
        "likes": {
          "type": "integer",
          "description": "Like counter"
        },
        "likers": {
          "type": "array",
          "description": "Array of Firebase UIDs who liked this post"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "published"],
          "description": "The publishing state of the article"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        },
        "seriesId": {
          "type": "string",
          "description": "The unique ID of the series/novel the article belongs to"
        },
        "seriesTitle": {
          "type": "string",
          "description": "The title of the series/novel"
        },
        "seriesOrder": {
          "type": "integer",
          "description": "Chapter sequencing order inside the series"
        }
      },
      "required": ["title", "content", "authorId", "authorName", "status", "createdAt", "updatedAt"]
    },
    "Series": {
      "title": "Novel Series / Serialization Column",
      "description": "Sequenced serialization column/book folder created by author or owner",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the series" },
        "description": { "type": "string", "description": "Short bio/summary of the series" },
        "authorId": { "type": "string", "description": "Author owner's UID" },
        "authorName": { "type": "string", "description": "Author owner's name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "description", "authorId", "authorName", "createdAt"]
    },
    "Follow": {
      "title": "User Follow Relationship",
      "description": "Indicates when a user follows another user",
      "type": "object",
      "properties": {
        "followerId": { "type": "string", "description": "The UID of the user who followed" },
        "followerName": { "type": "string", "description": "Display name of follower" },
        "followerAvatar": { "type": "string", "description": "Avatar of follower" },
        "followingId": { "type": "string", "description": "The UID of the user being followed" },
        "followingName": { "type": "string", "description": "Display name of following user" },
        "followingAvatar": { "type": "string", "description": "Avatar of following user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Follow timestamp" }
      },
      "required": ["followerId", "followerName", "followerAvatar", "followingId", "followingName", "followingAvatar", "createdAt"]
    },
    "Notification": {
      "title": "System / Interpersonal Notification",
      "description": "A notification pushed to a user",
      "type": "object",
      "properties": {
        "recipientId": { "type": "string", "description": "The UID of the user who receives the notification" },
        "senderId": { "type": "string", "description": "The UID of the user who triggered the notification" },
        "senderName": { "type": "string", "description": "Display name of sender" },
        "senderAvatar": { "type": "string", "description": "Avatar of sender" },
        "type": { "type": "string", "enum": ["new_post", "follow", "like", "system"], "description": "Categorization of notification type" },
        "title": { "type": "string", "description": "Brief notification title" },
        "body": { "type": "string", "description": "Notification body details" },
        "postId": { "type": "string", "description": "Optional related post UID" },
        "postTitle": { "type": "string", "description": "Optional related post title" },
        "read": { "type": "boolean", "description": "Read / Unread status flag" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["recipientId", "senderId", "senderName", "type", "title", "body", "read", "createdAt"]
    },
    "Report": {
      "title": "Abuse / Content Report",
      "description": "A user-submitted abuse report against an article",
      "type": "object",
      "properties": {
        "postId": { "type": "string", "description": "ID of the reported post" },
        "postTitle": { "type": "string", "description": "Title of the reported post" },
        "reporterId": { "type": "string", "description": "UID of the reporter" },
        "reporterName": { "type": "string", "description": "Name of the reporter" },
        "reason": { "type": "string", "enum": ["引战", "R18内容但无加入R18标签", "非R18博文图片带有R18图片"], "description": "Primary report reason" },
        "details": { "type": "string", "description": "Detailed description of violation" },
        "status": { "type": "string", "enum": ["pending", "resolved", "invalid"], "description": "Report handling status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when report was filed" }
      },
      "required": ["postId", "postTitle", "reporterId", "reporterName", "reason", "status", "createdAt"]
    },
    "AuthorApplication": {
      "title": "Author Qualification Application",
      "description": "An application submitted by a reader to become an author",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the applicant" },
        "username": { "type": "string", "description": "Display name of applicant" },
        "email": { "type": "string", "format": "email", "description": "Email address of applicant" },
        "bio": { "type": "string", "description": "Applicant bio or reason" },
        "sampleContent": { "type": "string", "description": "Self-introduction or prior works" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Review status" },
        "rejectReason": { "type": "string", "description": "Optional reason for rejection" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Application submission timestamp" }
      },
      "required": ["userId", "username", "email", "bio", "status", "createdAt"]
    },
    "WritingSubscription": {
      "title": "Author Writing Plan Subscription",
      "description": "Indicates when a user subscribes to an author's update schedules and punch-in alerts",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The subscriber's UID" },
        "username": { "type": "string", "description": "The subscriber's username" },
        "authorId": { "type": "string", "description": "The author's UID" },
        "authorName": { "type": "string", "description": "The author's username" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Subscription timestamp" }
      },
      "required": ["userId", "username", "authorId", "authorName", "createdAt"]
    },
    "Comment": {
      "title": "Post Comment",
      "description": "Comments and author replies on a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string", "description": "ID of the associated post" },
        "userId": { "type": "string", "description": "UID of the commenter" },
        "username": { "type": "string", "description": "Username of the commenter" },
        "avatar": { "type": "string", "description": "Avatar of the commenter" },
        "content": { "type": "string", "description": "Body text of the comment" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "replies": { "type": "array", "description": "Author or moderator replies" }
      },
      "required": ["postId", "userId", "username", "content", "createdAt"]
    },
    "Message": {
      "title": "Private Message",
      "description": "Private direct letters between users",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "UID of the message sender" },
        "senderName": { "type": "string", "description": "Name of the message sender" },
        "senderAvatar": { "type": "string", "description": "Avatar of the message sender" },
        "recipientId": { "type": "string", "description": "UID of the message recipient" },
        "recipientName": { "type": "string", "description": "Name of the message recipient" },
        "recipientAvatar": { "type": "string", "description": "Avatar of the message recipient" },
        "body": { "type": "string", "description": "Content body of the direct message" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "read": { "type": "boolean", "description": "Unread indicator" }
      },
      "required": ["senderId", "senderName", "recipientId", "recipientName", "body", "createdAt", "read"]
    },
    "Announcement": {
      "title": "System Announcement",
      "description": "Global system announcements displayed on homepage",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the announcement" },
        "content": { "type": "string", "description": "Content body in markdown or plain text" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Publication timestamp" },
        "active": { "type": "boolean", "description": "Whether the announcement is currently visible" }
      },
      "required": ["title", "content", "createdAt", "active"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles indexed by their Firebase UID"
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Articles and drafts"
    },
    "series/{seriesId}": {
      "schema": "Series",
      "description": "Novel series/columns"
    },
    "follows/{followId}": {
      "schema": "Follow",
      "description": "User follow records"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Pushed alerts and notifications"
    },
    "reports/{reportId}": {
      "schema": "Report",
      "description": "User filed abuse/content reports"
    },
    "author_applications/{appId}": {
      "schema": "AuthorApplication",
      "description": "Applications to become an author"
    },
    "writing_subscriptions/{subId}": {
      "schema": "WritingSubscription",
      "description": "Subscriptions to author writing schedules and punch-ins"
    },
    "comments/{commentId}": {
      "schema": "Comment",
      "description": "Reader comments and replies on posts"
    },
    "messages/{messageId}": {
      "schema": "Message",
      "description": "Private direct letters between users"
    },
    "announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Global system announcements displayed on homepage"
    }
  }
}
